[submodule "ohmyzsh"]
	path = ohmyzsh
	url = https://github.com/ohmyzsh/ohmyzsh.git
[submodule "zathura"]
	path = zathura
	url = https://github.com/dracula/zathura
[submodule ".config/zathura"]
	path = .config/zathura
	url = https://github.com/dracula/zathura
[submodule ".config/neofetch/neofetch-themes"]
	path = .config/neofetch/neofetch-themes
	url = https://github.com/Chick2D/neofetch-themes/
[submodule ".tmux"]
	path = .tmux
	url = https://github.com/gpakosz/.tmux/tree/master
